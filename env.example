# ============================================================
# Kindle Worksheet Emailer — Environment Variables
# ============================================================
# Copy this file to .env for local development
# cp .env.example .env
# Fill in your real values in .env
# NEVER commit .env to GitHub
# ============================================================

# ------------------------------------------------------------
# GoDaddy SMTP — email sending
# ------------------------------------------------------------
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=you@sudharsankr.co.in
SMTP_PASS=your_godaddy_email_password
EMAIL_FROM=you@sudharsankr.co.in

# ------------------------------------------------------------
# Google Cloud — project and GCS bucket
# ------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCS_BUCKET_NAME=sudharsankr-worksheets
